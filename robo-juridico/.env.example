# ══════════════════════════════════════════════════════════════════════
#  ⚙️  EXEMPLO DE CONFIGURAÇÃO — copie para .env e preencha os valores
#  ⚠️  NUNCA commite o arquivo .env no Git!
# ══════════════════════════════════════════════════════════════════════

# ── Gmail (IMAP) ──────────────────────────────────────────────────────
EMAIL_LOGIN=seu_email@gmail.com
SENHA_APP=xxxx xxxx xxxx xxxx
IMAP_SERVER=imap.gmail.com

# Pasta de rascunhos: "[Gmail]/Rascunhos" (PT) ou "[Gmail]/Drafts" (EN)
PASTA_DRAFTS=[Gmail]/Rascunhos

# ── Planilha de clientes ──────────────────────────────────────────────
ARQUIVO_CLIENTES=clientes.xlsx

# ── API do DJEN / CNJ ─────────────────────────────────────────────────
# Opção 1 (manual): cole o token gerado por node jwt-tools/gen_pjud.js
DJEN_API_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
DJEN_TOKEN=

# Opção 2 (automático): configure a chave PEM e CPF — o sistema gera o token sozinho
# Cole todo o conteúdo do arquivo .pem (incluindo -----BEGIN/END-----)
# No Replit: adicione como Secret com o nome PDPJ_PEM_PRIVATE_KEY
PDPJ_PEM_PRIVATE_KEY=
ADVOGADO_CPF=09494128648

# ── Google Drive (opcional) ───────────────────────────────────────────
# Defina SALVAR_NO_DRIVE=true para ativar o upload automático de PDFs
SALVAR_NO_DRIVE=false
# ID da pasta do Drive (cole o ID que aparece na URL ao abrir a pasta)
PASTA_DRIVE_ID=
